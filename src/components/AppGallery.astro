---
import { Image as ImageIcon, Monitor, Server, Workflow } from 'lucide-astro';

const screenshots = [
  {
    title: "Interfaz de Punto de Venta",
    description: "Facturación ultrarrápida diseñada para uso intensivo de teclado y lectores de códigos de barras.",
    icon: Monitor,
    gradient: "from-z-blue/40 to-z-dark",
    border: "border-z-blue/50"
  },
  {
    title: "Gestión de Inventario y SQLite",
    description: "Control de stock en tiempo real respaldado por una base de datos offline inquebrantable.",
    icon: Server,
    gradient: "from-z-gold/30 to-z-dark",
    border: "border-z-gold/40"
  },
  {
    title: "Caja Registradora y Reportes Z",
    description: "Cálculos precisos, manejo seguro de dinero y auditoría estricta de cada movimiento.",
    icon: Workflow,
    gradient: "from-z-blue-dark/50 to-z-dark",
    border: "border-z-blue-dark/60"
  }
];
---
<section id="galeria" class="py-24 bg-z-dark border-t border-z-blue-dark relative overflow-hidden">
    <!-- Decorative background elements to match the Hero section's premium feel -->
    <div class="absolute top-0 right-0 -translate-y-12 translate-x-1/3 w-96 h-96 bg-z-blue-dark/50 rounded-full blur-3xl z-0 pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 translate-y-1/3 -translate-x-1/3 w-96 h-96 bg-z-gold/10 rounded-full blur-3xl z-0 pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="text-center mb-16 reveal-up">
            <h2 class="text-3xl font-extrabold text-white sm:text-4xl">Interfaz del Sistema</h2>
            <p class="mt-4 text-lg text-z-light/70 max-w-2xl mx-auto">Diseñada para una fiabilidad extrema. Un diseño limpio y conciso que funciona impecablemente desde sistemas legacy de 32 bits hasta entornos modernos.</p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {screenshots.map((shot, index) => {
                const Icon = shot.icon;
                const delayClass = `delay-${((index % 3) + 1) * 100}`;
                return (
                    <div class={`group rounded-xl overflow-hidden border ${shot.border} bg-z-blue-dark/40 backdrop-blur-sm transition-all duration-500 ease-out hover:shadow-xl hover:shadow-z-blue/20 hover:-translate-y-1 flex flex-col reveal-up ${delayClass}`}>
                        <!-- Placeholder for actual image -->
                        <div class={`w-full aspect-video bg-gradient-to-br ${shot.gradient} flex items-center justify-center relative overflow-hidden border-b border-z-blue-dark/50`}>
                            <div class="absolute inset-0 bg-z-dark/60 opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex flex-col items-center justify-center gap-2 z-10">
                                <ImageIcon class="w-8 h-8 text-white opacity-90" />
                                <span class="text-xs font-semibold text-white tracking-widest uppercase opacity-90">Próximamente</span>
                            </div>
                            <Icon class="w-16 h-16 text-z-blue/50 group-hover:scale-105 transition-transform duration-700 ease-out z-0" />
                        </div>
                        <div class="p-6 flex-grow flex flex-col justify-center">
                            <h3 class="text-xl font-bold text-z-light mb-2">{shot.title}</h3>
                            <p class="text-z-light/70 text-sm leading-relaxed">{shot.description}</p>
                        </div>
                    </div>
                );
            })}
        </div>
        
        <div class="mt-16 text-center">
             <p class="text-z-blue text-sm italic flex items-center justify-center gap-2">
                <Monitor class="w-4 h-4" />
                <span>Las capturas de pantalla reales de la aplicación WPF/WinForms se integrarán pronto.</span>
             </p>
        </div>
    </div>
</section>
