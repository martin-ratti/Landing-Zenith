---
import { Info, Keyboard, Zap, ShieldAlert, MousePointer2, Smartphone, X } from 'lucide-astro';

const base = import.meta.env.BASE_URL;

const hotspots = [
    {
        id: "scanner",
        x: "9.5%",
        y: "22.5%",
        icon: Zap,
        color: "rgb(20, 61, 115)", // z-blue
        title: "Velocidad Extrema",
        description: "Conecta cualquier lector de código de barras USB. Los productos se agregan al instante sin tocar el mouse.",
        position: "left-start"
    },
    {
        id: "stock",
        x: "40%",
        y: "10.5%",
        icon: ShieldAlert,
        color: "rgb(239, 68, 68)", // red-500
        title: "Vigilancia en Tiempo Real",
        description: "El sistema audita tu inventario mientras cobras y te avisa qué mercadería está por agotarse.",
        position: "top"
    },
    {
        id: "vuelto",
        x: "26%",
        y: "89.5%",
        icon: Info,
        color: "rgb(191, 121, 59)", // z-gold
        title: "Cero Errores",
        description: "Ingresa el pago y el sistema indica el vuelto exacto. Cierra la venta con seguridad total.",
        position: "bottom"
    },
    {
        id: "cierre",
        x: "93%",
        y: "88%",
        icon: Keyboard,
        color: "rgb(22, 163, 74)", // green-600
        title: "Flujo 100% Teclado",
        description: "Asigna el pago y cierra la venta en milisegundos usando solo las teclas de función [F1-F12].",
        position: "right-end"
    }
];
---

<section id="galeria" class="py-24 bg-white overflow-hidden relative border-b border-z-blue-dark/5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <!-- Header -->
        <div class="text-center mb-16 reveal-up">
            <span class="inline-block px-4 py-1 bg-z-gold/5 text-z-gold rounded-full text-[10px] font-black tracking-widest uppercase mb-4 border border-z-gold/10">
                Centro de Mando
            </span>
            <h2 class="text-3xl md:text-5xl font-black text-z-dark mb-4 tracking-tight leading-tight">
                VELOCIDAD SIN <span class="bg-clip-text text-transparent bg-linear-to-r from-z-gold to-amber-600">DISTRACCIONES</span>
            </h2>
            <p class="text-slate-500 max-w-2xl mx-auto font-medium">
                Una interfaz limpia donde el mouse no es bienvenido. Diseñado para cajeros que valoran cada milisegundo de su turno.
            </p>
        </div>

        <!-- Showcase -->
        <div class="max-w-5xl mx-auto reveal-up delay-200">
            <div class="relative group/interface">
                <!-- Marco de la Interface -->
                <div class="relative rounded-2xl md:rounded-3xl overflow-hidden shadow-2xl shadow-z-dark/20 border border-slate-200">
                    <img 
                        src={`${base}/pos-interface.png`} 
                        alt="Zenith POS Interface" 
                        class="w-full h-auto"
                    />

                    <!-- Hotspots Layer -->
                    <div class="absolute inset-0">
                        {hotspots.map((h) => {
                            const Icon = h.icon;
                            return (
                                <div 
                                    class="hotspot-group absolute" 
                                    style={`top: ${h.y}; left: ${h.x};`}
                                    data-id={h.id}
                                    data-title={h.title}
                                    data-description={h.description}
                                    data-color={h.color}
                                >
                                    <!-- Punto Pulsante -->
                                    <div class="relative flex items-center justify-center cursor-pointer hotspot-trigger">
                                        <div class="absolute w-6 h-6 rounded-full bg-white opacity-40 animate-ping"></div>
                                        <div class="relative z-10 w-4 h-4 rounded-full border-2 border-white shadow-lg ring-2 ring-transparent transition-all duration-300" style={`background-color: ${h.color};`}></div>
                                    </div>

                                    <!-- Línea Conectora (PC) -->
                                    <div class="hotspot-line absolute hidden md:block"></div>

                                    <!-- Card de Info (PC) -->
                                    <div class="hotspot-card absolute opacity-0 pointer-events-none transition-all duration-300 transform scale-95 z-50 hidden md:block">
                                        <div class="bg-z-dark/95 backdrop-blur-md p-4 rounded-xl border border-white/10 shadow-2xl w-64">
                                            <div class="flex items-center gap-2 mb-2">
                                                <Icon class="w-4 h-4 text-z-gold" />
                                                <h4 class="text-white font-bold text-sm tracking-tight">{h.title}</h4>
                                            </div>
                                            <p class="text-zinc-400 text-xs leading-relaxed">{h.description}</p>
                                        </div>
                                    </div>
                                </div>
                            )
                        })}
                    </div>
                </div>
                <!-- Mobile Modal (Unified) -->
                <div id="hotspot-mobile-modal" class="md:hidden fixed inset-x-4 top-1/2 -translate-y-1/2 z-[100] opacity-0 pointer-events-none transition-all duration-500 transform scale-95">
                    <div class="bg-z-dark/95 backdrop-blur-xl p-6 rounded-3xl border border-white/10 shadow-[0_30px_100px_rgba(0,0,0,0.6)] relative overflow-hidden">
                        <!-- Color Accent Bar -->
                        <div id="modal-accent-bar" class="absolute top-0 left-0 w-full h-1.5 shadow-sm"></div>
                        
                        <!-- Close X -->
                        <button id="close-modal-btn" class="absolute top-4 right-4 w-10 h-10 bg-white/5 text-white rounded-full flex items-center justify-center active:bg-white/10 transition-colors">
                            <X class="w-6 h-6" />
                        </button>

                        <div class="pt-2">
                            <h4 id="modal-title" class="text-white font-black text-xl tracking-tight mb-4 flex items-center gap-3">
                                <Zap class="w-6 h-6 text-z-gold" />
                                <span>Título</span>
                            </h4>
                            <p id="modal-description" class="text-slate-400 text-sm leading-relaxed"></p>
                        </div>
                    </div>
                </div>

                <!-- Mobile Overlay -->
                <div class="hotspot-overlay md:hidden"></div>
            </div>
        </div>

        <!-- Mobile Onboarding Prompt -->
        <div class="mt-8 flex md:hidden flex-col items-center gap-2 reveal-up">
            <p class="text-slate-500 font-medium text-sm animate-pulse flex items-center gap-2">
                <Smartphone class="w-4 h-4" />
                <span>👆 Toca los puntos resaltados para explorar</span>
            </p>
        </div>
    </div>
</section>

<style>
    /* Hotspot Grouping */
    .hotspot-group {
        transform: translate(-50%, -50%);
    }

    /* Líneas Dinámicas */
    .hotspot-line {
        height: 1px;
        background: linear-gradient(to right, white, transparent);
        width: 40px;
        opacity: 0.3;
        top: 50%;
        left: 50%;
        transform-origin: left center;
        transition: all 0.5s ease;
    }

    /* Posicionamiento de Cards según la propiedad h.position */
    [data-id="scanner"] .hotspot-card { top: -20px; left: 60px; }
    [data-id="scanner"] .hotspot-line { rotate: 0deg; left: 20px; width: 40px; }

    [data-id="stock"] .hotspot-card { top: 60px; left: 0; transform: translateX(-50%) scale(0.95); }
    [data-id="stock"] .hotspot-line { rotate: 90deg; left: 50%; top: 20px; width: 40px; }

    [data-id="vuelto"] .hotspot-card { bottom: 60px; left: 0; transform: translateX(-50%) scale(0.95); }
    [data-id="vuelto"] .hotspot-line { rotate: -90deg; left: 50%; bottom: 20px; width: 40px; }

    [data-id="cierre"] .hotspot-card { bottom: -20px; right: 60px; }
    [data-id="cierre"] .hotspot-line { rotate: 180deg; right: 20px; left: auto; width: 40px; }

    /* Hover States */
    .hotspot-group:hover .hotspot-card {
        opacity: 1;
        pointer-events: auto;
        transform: translate(0, 0) scale(1);
        z-index: 100 !important;
    }
    
    [data-id="stock"]:hover .hotspot-card, 
    [data-id="vuelto"]:hover .hotspot-card {
        transform: translateX(-50%) scale(1);
    }

    .hotspot-group:hover .hotspot-line {
        opacity: 0.8;
        width: 50px;
        background-color: var(--color-z-gold);
    }

    .hotspot-group:hover .hotspot-trigger div {
        transform: scale(1.2);
    }

    /* Mobile Info Modal Support */
    #hotspot-mobile-modal.active {
        opacity: 1;
        pointer-events: auto;
        transform: translate(0, -50%) scale(1);
    }

    /* Overlay */
    .hotspot-overlay {
        position: fixed;
        inset: 0;
        background: rgba(1, 6, 38, 0.85); /* z-dark color matched */
        backdrop-filter: blur(8px);
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.4s ease;
        z-index: 90;
    }

    .hotspot-overlay.active {
        opacity: 1;
        pointer-events: auto;
    }
</style>

<script>
    function setupInteractive() {
        const groups = document.querySelectorAll('.hotspot-group');
        const overlay = document.querySelector('.hotspot-overlay');
        const mobileModal = document.getElementById('hotspot-mobile-modal');
        const modalTitle = document.getElementById('modal-title');
        const modalDesc = document.getElementById('modal-description');
        const modalAccent = document.getElementById('modal-accent-bar');
        const closeBtn = document.getElementById('close-modal-btn');
        
        const closeMobileModal = () => {
            mobileModal?.classList.remove('active');
            overlay?.classList.remove('active');
            document.body.style.overflow = '';
        };

        groups.forEach(group => {
            const trigger = group.querySelector('.hotspot-trigger');
            
            trigger?.addEventListener('click', (e) => {
                e.stopPropagation();
                
                if (window.innerWidth <= 768) {
                    // Mobile Behavior: Global Modal
                    const title = group.getAttribute('data-title');
                    const desc = group.getAttribute('data-description');
                    const color = group.getAttribute('data-color');
                    
                    if (modalTitle && modalDesc && modalAccent && mobileModal) {
                        modalTitle.querySelector('span')!.textContent = title || '';
                        modalDesc.textContent = desc || '';
                        modalAccent.style.backgroundColor = color || '';
                        
                        mobileModal.classList.add('active');
                        overlay?.classList.add('active');
                        document.body.style.overflow = 'hidden';
                    }
                } else {
                    // Desktop Behavior: Tooltips
                    groups.forEach(g => {
                        if (g !== group) g.classList.remove('active');
                    });
                    group.classList.toggle('active');
                }
            });
        });

        // Close Events
        closeBtn?.addEventListener('click', closeMobileModal);
        overlay?.addEventListener('click', closeMobileModal);
        
        document.addEventListener('click', (e) => {
            if (!(e.target as HTMLElement).closest('.hotspot-group') && !(e.target as HTMLElement).closest('#hotspot-mobile-modal')) {
                groups.forEach(g => g.classList.remove('active'));
                closeMobileModal();
            }
        });
    }

    // Ejecutar inicializador
    setupInteractive();
</script>
```
