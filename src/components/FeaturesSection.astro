---
import { ShoppingCart, Package, Banknote, BarChart3, Users, ShieldCheck, Info, ChevronRight, X, MessageCircle } from 'lucide-astro';

const base = import.meta.env.BASE_URL;

const features = [
    { 
        id: "ventas",
        title: "Ventas y Control Interno", 
        description: "Caja registradora rápida, soporte para lectores de códigos de barras e impresión de tickets.", 
        icon: ShoppingCart,
        badge: "Solo Control Interno",
        badgeTooltip: "Programa de gestión interna, no permite facturación fiscal con ARCA/AFIP",
        details: [
            "Carga de productos por código de barras o búsqueda rápida.",
            "Suspensión de ventas en curso para atención simultánea.",
            "Asociación rápida de ventas a clientes de confianza.",
            "Impresión de comprobantes no fiscales personalizables."
        ],
        video: `${base}/images/features/ventas.png`
    },
    { 
        id: "inventario",
        title: "Control de Inventario", 
        description: "Gestión de productos, categorías, marcas y alertas de stock mínimo en tiempo real.", 
        icon: Package,
        details: [
            "Alertas automáticas cuando el stock llega al mínimo.",
            "Historial de movimientos por producto (entradas y salidas).",
            "Clasificación por categorías, marcas y proveedores.",
            "Ajustes de inventario simplificados por pérdida o consumo."
        ],
        video: `${base}/images/features/inventario.png`
    },
    { 
        id: "caja",
        title: "Gestión de Caja", 
        description: "Apertura, cierres, registro de egresos y cálculo de reportes Z detallados.", 
        icon: Banknote,
        details: [
            "Control riguroso de ingresos y egresos de efectivo.",
            "Arqueos de caja por turno y por vendedor.",
            "Reportes Z automáticos al finalizar el día.",
            "Registro de gastos operativos diarios desde la caja."
        ],
        video: `${base}/images/features/caja.png`
    },
    { 
        id: "seguridad",
        title: "Seguridad y Empleados", 
        description: "Control de seguridad por niveles de acceso, registro de actividad por vendedor y auditoría de transacciones.", 
        icon: ShieldCheck,
        details: [
            "Permisos granulares por tipos de usuario (Admin, Cajero).",
            "Registro de aperturas y cierres de sesión.",
            "Auditoría detallada de cada ticket emitido.",
            "Bloqueos automáticos para funciones críticas."
        ],
        video: `${base}/images/features/seguridad.png`
    },
    { 
        id: "analiticas",
        title: "KPIs y Analíticas", 
        description: "Métricas clave de rendimiento (KPIs), productos más vendidos y análisis histórico.", 
        icon: BarChart3,
        details: [
            "Dashboard intuitivo con métricas de ventas diarias.",
            "Reporte de productos 'Top-Seller' del mes.",
            "Ranking de vendedores por volumen de operación.",
            "Visualización rápida de recaudación total por turno."
        ],
        video: `${base}/images/features/analiticas.png`
    },
    { 
        id: "clientes",
        title: "Clientes y Proveedores", 
        description: "Control de cuentas corrientes, deudas, pagos y recepción de mercadería.", 
        icon: Users,
        details: [
            "Gestión de saldos para clientes con crédito.",
            "Seguimiento de deudas con proveedores externos.",
            "Registro de pagos parciales y abonos.",
            "Historial completo de compras y ventas por entidad."
        ],
        video: `${base}/images/features/clientes.png`
    }
];
---
<section id="caracteristicas" class="py-20 bg-z-light overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16 reveal-up">
            <h2 class="text-3xl font-extrabold text-z-dark sm:text-4xl">Módulos del Sistema</h2>
            <p class="mt-4 text-lg text-z-blue-dark max-w-2xl mx-auto">No permitas que un corte de internet o un servidor lento detenga tus ventas. Todo lo que necesitas para operar de forma segura, integrado en un ecosistema local.</p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8">
            {features.map((feature, index) => {
                const Icon = feature.icon;
                const delayClass = `delay-${((index % 3) + 1) * 100}`;
                const isPremium = index < 3; // La Trinidad (Ventas, Inventario, Caja)
                
                return (
                    <div 
                        class={`bg-white rounded-2xl p-8 hover:shadow-xl hover:-translate-y-2 transition-all duration-500 ease-out group reveal-up ${delayClass} h-full flex flex-col relative overflow-hidden backdrop-blur-sm border-2 ${isPremium ? 'border-z-gold/50 shadow-sm shadow-z-gold/10' : 'border-z-blue-dark/5 shadow-sm'}`}
                        data-feature-id={feature.id}
                    >
                        <!-- Badge Disclaimer (Solo Ventas) -->
                        {feature.badge && (
                            <div class="absolute top-4 right-4 z-20">
                                <div class="relative group/tooltip">
                                    <div class="flex items-center gap-1.5 px-3 py-1 bg-amber-50 border border-amber-200 text-amber-600 rounded-full text-[10px] font-bold tracking-wider uppercase shadow-sm">
                                        <span>{feature.badge}</span>
                                        <Info class="w-3 h-3" />
                                    </div>
                                    <!-- Tooltip -->
                                    <div class="absolute bottom-full right-0 mb-2 w-48 p-2 bg-z-dark text-white text-[10px] rounded-lg opacity-0 pointer-events-none group-hover/tooltip:opacity-100 transition-opacity duration-300 z-30 shadow-xl border border-white/10 text-center">
                                        {feature.badgeTooltip}
                                        <div class="absolute top-full right-6 w-2 h-2 bg-z-dark rotate-45 transform -translate-y-1"></div>
                                    </div>
                                </div>
                            </div>
                        )}

                        <!-- GIF Background Reveal (Intelligent Lazy Loading via JS) -->
                        <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-all duration-700 ease-out z-0">
                            <!-- Imagen simulando la App (Se cargará al hacer hover) -->
                                <img 
                                    data-src={feature.video} 
                                    src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 800 600'%3E%3C/svg%3E" 
                                    alt={`Demostración de ${feature.title}`} 
                                    class="w-full h-full object-cover object-top transform scale-110 group-hover:scale-100 transition-transform duration-1000 ease-out feature-gif" 
                                />
                            <!-- Overlay oscuro refinado -->
                            <div class="absolute inset-0 bg-z-dark/80 backdrop-blur-[2px]"></div>
                        </div>

                        <!-- SVG Icon Container -->
                        <div class={`mb-6 inline-flex p-4 rounded-xl transition-all duration-500 ease-out transform group-hover:scale-90 group-hover:-translate-y-2 shadow-sm self-start relative z-10 ${isPremium ? 'bg-linear-to-br from-z-gold to-amber-400 text-white shadow-z-gold/20' : 'bg-z-light text-z-blue-dark'}`}>
                            <Icon class="w-7 h-7" />
                        </div>
                        
                        <!-- Content -->
                        <div class="relative z-10 flex flex-col grow">
                            <h3 class="text-xl font-bold text-z-dark mb-3 group-hover:text-white transition-colors duration-500">{feature.title}</h3>
                            <p class="text-z-blue-dark/70 text-sm leading-relaxed group-hover:text-z-light/80 transition-colors duration-500 mb-6">{feature.description}</p>
                            
                            <!-- Ver todas las funciones Button -->
                            <button 
                                class="mt-auto flex items-center gap-2 text-xs font-bold text-z-blue group-hover:text-z-gold transition-colors duration-300 open-modal-btn cursor-pointer"
                                data-feature-id={feature.id}
                            >
                                VER TODAS LAS FUNCIONES
                                <ChevronRight class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" />
                            </button>
                        </div>
                    </div>
                );
            })}
        </div>
    </div>

    <!-- Modal de Funciones (Diseño Premium) -->
    <div 
        id="feature-modal" 
        class="fixed inset-0 z-50 flex items-center justify-center p-4 opacity-0 pointer-events-none transition-opacity duration-300 bg-z-dark/85"
        aria-hidden="true"
    >
        <!-- Backdrop (Close on click) -->
        <div class="absolute inset-0 close-modal"></div>
        
        <!-- Modal Content -->
        <div id="modal-container" class="relative bg-white rounded-3xl w-full max-w-4xl max-h-[90vh] overflow-hidden shadow-2xl flex flex-col md:flex-row transform scale-95 transition-transform duration-300 ease-out">
            <!-- Close Button -->
            <button class="absolute top-4 right-4 z-50 p-2 bg-z-light rounded-full text-z-dark hover:bg-z-gold hover:text-white transition-colors close-modal pointer-events-auto shadow-md">
                <X class="w-5 h-5" />
            </button>

            <!-- Media Section (Real Screenshot) -->
            <div class="w-full md:w-1/2 bg-z-dark flex items-center justify-center overflow-hidden border-b md:border-b-0 md:border-r border-z-blue-dark/10 p-4">
                <img id="modal-image" src="" alt="Vista del sistema" class="w-full h-auto max-h-full object-contain shadow-2xl rounded-lg" />
            </div>

            <!-- Text Section -->
            <div class="w-full md:w-1/2 p-8 md:p-12 overflow-y-auto">
                <span class="inline-block px-3 py-1 bg-z-gold/10 text-z-gold rounded-full text-[10px] font-bold tracking-widest uppercase mb-4">Módulo Detallado</span>
                <h2 id="modal-title" class="text-3xl font-black text-z-dark mb-6 tracking-tight uppercase"></h2>
                
                <div class="space-y-4 mb-10">
                    <h4 class="text-sm font-bold text-z-blue-dark uppercase tracking-wide">Funcionalidades principales:</h4>
                    <ul id="modal-details" class="space-y-3">
                        <!-- Bullet points injectados via JS -->
                    </ul>
                </div>

                <a 
                    href="https://wa.me/5493464441120?text=Hola!%20Me%20interesa%20el%20módulo%20de..." 
                    id="modal-wa-link"
                    target="_blank"
                    class="flex items-center justify-center gap-3 w-full py-4 bg-z-dark text-white rounded-xl font-bold hover:bg-z-gold transition-colors shadow-lg hover:shadow-z-gold/30 hover:-translate-y-1"
                >
                    <MessageCircle class="w-5 h-5" />
                    CONSULTAR POR ESTE MÓDULO
                </a>
            </div>
        </div>
    </div>
</section>

<style>
    #feature-modal.is-open {
        opacity: 1;
        pointer-events: auto;
    }
    
    #feature-modal.is-open #modal-container {
        transform: scale(1);
    }

    /* Scrollbar minimalista para el modal */
    #modal-container div::-webkit-scrollbar {
        width: 6px;
    }
    #modal-container div::-webkit-scrollbar-track {
        background: transparent;
    }
    #modal-container div::-webkit-scrollbar-thumb {
        background: #e2e8f0;
        border-radius: 10px;
    }
    #modal-container div::-webkit-scrollbar-thumb:hover {
        background: #cbd5e1;
    }
</style>

<script is:inline define:vars={{ features }}>
    function initFeatures() {
        const modal = document.getElementById('feature-modal');
        const modalTitle = document.getElementById('modal-title');
        const modalImage = document.getElementById('modal-image');
        const modalDetails = document.getElementById('modal-details');
        const modalWaLink = document.getElementById('modal-wa-link');
        const openBtns = document.querySelectorAll('.open-modal-btn');
        const closeBtns = document.querySelectorAll('.close-modal');

        if (!modal) return;

        function openModal(featureId) {
            const feature = features.find(f => f.id === featureId);
            if (!feature) return;

            modalTitle.textContent = feature.title;
            modalImage.src = feature.video;
            modalWaLink.href = `https://wa.me/5493464441120?text=Hola!%20Me%20interesa%20el%20módulo%20${encodeURIComponent(feature.title)}%20del%20sistema%20Zenith%20POS.`;

            // Render details
            modalDetails.innerHTML = feature.details.map(detail => `
                <li class="flex items-start gap-3 group">
                    <div class="mt-1 w-5 h-5 rounded-full bg-z-gold/20 flex items-center justify-center shrink-0">
                        <svg class="w-3 h-3 text-z-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                    </div>
                    <span class="text-z-blue-dark/80 text-sm leading-snug font-medium transition-colors group-hover:text-z-dark">${detail}</span>
                </li>
            `).join('');

            modal.classList.add('is-open');
            modal.setAttribute('aria-hidden', 'false');
            document.body.style.overflow = 'hidden';
            document.body.style.paddingRight = (window.innerWidth - document.documentElement.clientWidth) + 'px';
        }

        function closeModal() {
            modal.classList.remove('is-open');
            modal.setAttribute('aria-hidden', 'true');
            
            setTimeout(() => {
                document.body.style.overflow = '';
                document.body.style.paddingRight = '';
            }, 300);
        }

        openBtns.forEach(btn => {
            btn.onclick = (e) => {
                e.preventDefault();
                e.stopPropagation();
                openModal(btn.dataset.featureId);
            };
        });

        closeBtns.forEach(btn => {
            btn.onclick = (e) => {
                e.preventDefault();
                closeModal();
            };
        });

        window.onkeydown = (e) => {
            if (e.key === 'Escape' && modal.classList.contains('is-open')) closeModal();
        };

        const cards = document.querySelectorAll('[data-feature-id]');
        cards.forEach(card => {
            card.onmouseenter = function() {
                const gif = this.querySelector('.feature-gif');
                if (gif && gif.src.startsWith('data:image')) {
                    gif.src = gif.dataset.src;
                }
            };
        });
    }

    // Ejecutar inmediatamente
    initFeatures();
</script>