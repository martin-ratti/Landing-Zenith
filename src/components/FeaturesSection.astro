---
import { ShoppingCart, Package, Banknote, BarChart3, Users, ShieldCheck } from 'lucide-astro';

const features = [
    { title: "Ventas y Control Interno", description: "Caja registradora rápida, soporte para lectores de códigos de barras e impresión de tickets. (Programa de gestión interna, no permite facturación fiscal).", icon: ShoppingCart },
    { title: "Control de Inventario", description: "Gestión de productos, categorías, marcas y alertas de stock mínimo en tiempo real.", icon: Package },
    { title: "Gestión de Caja", description: "Apertura, cierres, registro de egresos y cálculo de reportes Z detallados.", icon: Banknote },
    { title: "Seguridad y Empleados", description: "Control de seguridad por niveles de acceso, registro de actividad por vendedor y auditoría de transacciones para un control total.", icon: ShieldCheck },
    { title: "KPIs y Analíticas", description: "Métricas clave de rendimiento (KPIs), productos más vendidos y análisis histórico para toma de decisiones.", icon: BarChart3 },
    { title: "Clientes y Proveedores", description: "Control de cuentas corrientes, deudas, pagos y recepción de mercadería.", icon: Users }
];
---
<section id="caracteristicas" class="py-20 bg-z-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16 reveal-up">
            <h2 class="text-3xl font-extrabold text-z-dark sm:text-4xl">Módulos del Sistema</h2>
            <p class="mt-4 text-lg text-z-blue-dark max-w-2xl mx-auto">No permitas que un corte de internet o un servidor lento detenga tus ventas. Todo lo que necesitas para operar de forma segura, integrado en un ecosistema local.</p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {features.map((feature, index) => {
                const Icon = feature.icon;
                const delayClass = `delay-${((index % 3) + 1) * 100}`;
                return (
                    <div class={`bg-white rounded-xl shadow-sm border border-z-blue-dark/20 p-8 hover:shadow-lg hover:-translate-y-1 transition-all duration-500 ease-out group reveal-up ${delayClass} h-full flex flex-col`}>
                        <div class="mb-5 inline-flex p-4 rounded-lg bg-z-light text-z-blue-dark group-hover:bg-z-blue group-hover:text-white transition-all duration-500 ease-out transform group-hover:scale-105 self-start shadow-sm group-hover:shadow-md">
                            <Icon class="w-8 h-8" />
                        </div>
                        <h3 class="text-xl font-bold text-z-dark mb-3 group-hover:text-z-blue transition-colors duration-500">{feature.title}</h3>
                        <p class="text-z-blue-dark/80 leading-relaxed flex-grow">{feature.description}</p>
                    </div>
                );
            })}
        </div>
    </div>
</section>