---
const base = import.meta.env.BASE_URL;
---
<nav class="bg-z-dark border-b border-z-blue-dark sticky top-0 z-50 transition-all duration-300">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-20">
            <div class="shrink-0 flex items-center gap-3">
                    <img class="h-14 w-auto brightness-0 invert opacity-90" src={`${base}/images/LogoZenithSinFondo.png`} alt="Zenith POS Logo" />
            </div>

            <div class="hidden md:block">
                <div class="ml-10 flex items-baseline space-x-8">
                    <a href="#inicio" class="text-z-light/80 hover:text-white px-3 py-2 rounded-md text-sm font-medium transition-colors">Inicio</a>
                    <a href="#caracteristicas" class="text-z-light/80 hover:text-white px-3 py-2 rounded-md text-sm font-medium transition-colors">Módulos</a>
                    <a href="#galeria" class="text-z-light/80 hover:text-white px-3 py-2 rounded-md text-sm font-medium transition-colors">Galería</a>
                    <a href="#inversion" class="text-z-light/80 hover:text-white px-3 py-2 rounded-md text-sm font-medium transition-colors">Inversión</a>
                    <a href="#nosotros" class="text-z-light/80 hover:text-white px-3 py-2 rounded-md text-sm font-medium transition-colors">Nosotros</a>
                    <a href="#contacto" class="bg-z-blue hover:bg-z-blue-dark text-white px-4 py-2 rounded-md text-sm font-medium transition-colors shadow-lg shadow-z-blue/30">Contactar</a>
                </div>
            </div>
        </div>
    </div>
</nav>

<!-- Sticky CTA Bar -->
<div id="sticky-cta" class="fixed top-20 left-0 w-full z-40 bg-z-blue shadow-lg border-b border-z-blue-dark transition-all duration-500 ease-in-out transform -translate-y-full opacity-0">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-2 flex items-center justify-between text-white">
        <span class="font-medium text-sm sm:text-base">Empieza a organizar tu negocio hoy</span>
        <a href="#contacto" class="px-4 py-1.5 bg-white text-z-blue text-sm font-bold rounded hover:bg-z-light transition-colors shadow-sm">
            Solicitar Demo
        </a>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const stickyCta = document.getElementById('sticky-cta');
        if (stickyCta) {
            window.addEventListener('scroll', () => {
                if (window.scrollY > 100) {
                    stickyCta.classList.remove('-translate-y-full', 'opacity-0');
                    stickyCta.classList.add('translate-y-0', 'opacity-100');
                } else {
                    stickyCta.classList.add('-translate-y-full', 'opacity-0');
                    stickyCta.classList.remove('translate-y-0', 'opacity-100');
                }
            });
        }
    });
</script>